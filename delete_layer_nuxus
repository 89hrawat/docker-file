stage('Cleanup Old Nexus Images') {
    steps {
        withCredentials([
            usernamePassword(
                credentialsId: 'nexus-creds',
                usernameVariable: 'NEXUS_USER',
                passwordVariable: 'NEXUS_PASS'
            )
        ]) {
            sh '''#!/bin/bash

NEXUS_API="http://192.168.119.10:8081"
REPO="docker-host-repo"
KEEP=4
IMAGES="custom1/redis-master custom1/redis-slave custom1/php-fpm custom1/nginx"

# ── Python script to do safe cleanup ──
python3 << 'PYEOF'
import urllib.request
import urllib.parse
import json
import base64
import os
import sys

NEXUS_API  = "http://192.168.119.10:8081"
REPO       = "docker-host-repo"
KEEP       = 4
IMAGES     = [
    "custom1/redis-master",
    "custom1/redis-slave",
    "custom1/php-fpm",
    "custom1/nginx"
]

NEXUS_USER = os.environ["NEXUS_USER"]
NEXUS_PASS = os.environ["NEXUS_PASS"]

# Basic auth header
credentials = base64.b64encode(f"{NEXUS_USER}:{NEXUS_PASS}".encode()).decode()
HEADERS = {
    "Accept": "application/json",
    "Authorization": f"Basic {credentials}"
}

def nexus_get(url):
    req = urllib.request.Request(url, headers=HEADERS)
    with urllib.request.urlopen(req) as r:
        return json.loads(r.read().decode())

def nexus_delete(url):
    req = urllib.request.Request(url, method="DELETE", headers=HEADERS)
    try:
        with urllib.request.urlopen(req) as r:
            return r.status
    except urllib.error.HTTPError as e:
        return e.code

def get_all_versions(image_name):
    """Fetch all versions of an image from Nexus, sorted newest first."""
    items = []
    token = None
    while True:
        url = f"{NEXUS_API}/service/rest/v1/search?repository={REPO}&name={urllib.parse.quote(image_name)}"
        if token:
            url += f"&continuationToken={token}"
        data = nexus_get(url)
        items.extend(data.get("items", []))
        token = data.get("continuationToken")
        if not token:
            break

    # Sort by build number (version) descending — newest first
    items.sort(key=lambda x: int(x.get("version", 0)), reverse=True)
    return items

def get_manifest_sha256(image_name, tag):
    """
    Pull the manifest from the Docker registry API to get all layer sha256 digests.
    This tells us exactly which blob layers this image version uses.
    """
    url = (
        f"{NEXUS_API}/repository/{REPO}/v2/{image_name}/manifests/{tag}"
    )
    headers = dict(HEADERS)
    headers["Accept"] = "application/vnd.docker.distribution.manifest.v2+json"
    req = urllib.request.Request(url, headers=headers)
    try:
        with urllib.request.urlopen(req) as r:
            manifest = json.loads(r.read().decode())
            layers = set()
            # config blob
            if "config" in manifest:
                layers.add(manifest["config"]["digest"])
            # layer blobs
            for layer in manifest.get("layers", []):
                layers.add(layer["digest"])
            return layers
    except Exception as e:
        print(f"    ⚠  Could not fetch manifest for {image_name}:{tag} — {e}")
        return set()

def cleanup_image(image_name):
    print()
    print("==========================================")
    print(f"  Cleaning: {image_name}")
    print("==========================================")

    versions = get_all_versions(image_name)
    total = len(versions)

    if total == 0:
        print(f"  ⚠  No versions found.")
        return

    print(f"  📦 Found   : {total} version(s)")
    print(f"  ✔  Keeping : latest {KEEP}")

    if total <= KEEP:
        print(f"  ✅ Only {total} exist. Nothing to delete.")
        return

    keep_versions   = versions[:KEEP]
    delete_versions = versions[KEEP:]

    print(f"  🔍 Scanning layers used by versions we are KEEPING...")

    # Collect ALL layer sha256 digests used by the versions we keep
    keep_layers = set()
    for v in keep_versions:
        tag = v["version"]
        layers = get_manifest_sha256(image_name, tag)
        keep_layers.update(layers)
        print(f"     ✔ Keep  v{tag} — {len(layers)} layer(s)")

    print()
    print(f"  🗑  Checking {len(delete_versions)} old version(s) for safe deletion...")

    for v in delete_versions:
        tag     = v["version"]
        comp_id = v["id"]

        old_layers = get_manifest_sha256(image_name, tag)

        # Check if any layer in this old version is still needed by a kept version
        shared = old_layers & keep_layers

        if shared:
            # ── UNSAFE — skip deletion, layers are shared ──
            print(f"     ⚠  SKIP   v{tag} — shares {len(shared)} layer(s) with kept versions")
            print(f"              Shared layers: {list(shared)[:2]}{'...' if len(shared)>2 else ''}")
        else:
            # ── SAFE — no layers shared, delete it ──
            print(f"     🗑  DELETE v{tag} (component: {comp_id})")
            status = nexus_delete(
                f"{NEXUS_API}/service/rest/v1/components/{comp_id}"
            )
            if status == 204:
                print(f"     ✅ Deleted (HTTP 204)")
            elif status == 404:
                print(f"     ⚠  Already gone (HTTP 404)")
            elif status == 403:
                print(f"     ❌ Permission denied (HTTP 403) — check nx-component-delete role")
            else:
                print(f"     ❌ Failed (HTTP {status})")

# ── Run for all 4 images ──
for img in IMAGES:
    cleanup_image(img)

print()
print("==========================================")
print("  ✅ Nexus Cleanup Complete!")
print("==========================================")
PYEOF
            '''
        }
    }
}
